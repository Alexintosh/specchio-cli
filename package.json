{
  "name": "specchio",
  "version": "1.0.0",
  "description": "Interactive setup CLI for Specchio",
  "type": "module",
  "bin": {
    "specchio": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:standalone": "bun build src/index.ts --compile --outfile specchio",
    "build:all": "bash scripts/build-all.sh",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:verbose": "bun test --verbose",
    "test:release": "bash scripts/test-release.sh",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
